                  <div style="display:flex;align-items:center;height:2.75rem;border-radius:0.375rem;background:white;border:1px solid rgb(198,186,169);padding:0 0.75rem;gap:0.5rem;">
                    <span style="font-size:1.2rem;">🇺🇸</span>
